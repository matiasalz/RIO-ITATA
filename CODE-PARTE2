        "\n",
        "# 1. Configuración del entorno\n",
        "\n",
        "## 1.1 Clonar el repositorio desde GitHub\n",
        "\n",
        "Para acceder a los datos y scripts del curso, clonaremos el repositorio desde GitHub. Esto descarga todos los archivos necesarios en el entorno de Google Colab.\n",
        "\n",
        "> ⚠️ **Nota:** Esta celda solo debe ejecutarse **una vez** por sesión. Si el repositorio ya fue clonado, puedes omitir este paso."
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "import seaborn as sns\n",
        "\n",
        "# =================================================================\n",
        "# 1. CONFIGURACIÓN EXACTA DE TUS ARCHIVOS\n",
        "# =================================================================\n",
        "archivo_precip = \"/content/precip_cr2met_day.csv\"\n",
        "archivo_caudal = \"/content/q_mm_day.csv\"\n",
        "archivo_temp   = \"/content/tmax_cr2met_day.csv\"\n",
        "archivo_etp    = \"/content/pet_hargreaves_day.csv\"\n",
        "\n",
        "estacion = '8124002' # Río Itata en Trilaleo\n",
        "\n",
        "# =================================================================\n",
        "# 2. MOTOR DE LECTURA\n",
        "# =================================================================\n",
        "def leer_variable(ruta, nombre_var):\n",
        "    try:\n",
        "        df = pd.read_csv(ruta)\n",
        "        df.columns = df.columns.astype(str).str.strip().str.lower()\n",
        "\n",
        "        # Identify date components\n",
        "        if 'date' in df.columns:\n",
        "            df['fecha_full'] = pd.to_datetime(df['date'], errors='coerce')\n",
        "            df['anio'] = df['fecha_full'].dt.year\n",
        "            df['mes'] = df['fecha_full'].dt.month\n",
        "            df['dia'] = df['fecha_full'].dt.day\n",
        "        else:\n",
        "            c_anio = next((col for col in ['year', 'agno', 'anio', 'año'] if col in df.columns), None)\n",
        "            c_mes = next((col for col in ['month', 'mes'] if col in df.columns), None)\n",
        "            c_dia = next((col for col in ['day', 'dia'] if col in df.columns), None)\n",
        "\n",
        "            if not all([c_anio, c_mes, c_dia]):\n",
        "                raise KeyError(f\"No se encontraron todas las columnas de fecha (año, mes, día) en el archivo '{ruta}'. Columnas disponibles: {list(df.columns)}\")\n",
        "\n",
        "            df['anio'] = pd.to_numeric(df[c_anio], errors='coerce')\n",
        "            df['mes'] = pd.to_numeric(df[c_mes], errors='coerce')\n",
        "            df['dia'] = pd.to_numeric(df[c_dia], errors='coerce')\n",
        "\n",
        "        # Identify the data column\n",
        "        data_col_name = estacion.lower() # Use lower case to match normalized df columns\n",
        "        if data_col_name not in df.columns:\n",
        "            raise KeyError(f\"Columna de datos '{estacion}' no encontrada en el archivo '{ruta}'. Columnas disponibles: {list(df.columns)}\")\n",
        "\n",
        "        df[nombre_var] = pd.to_numeric(df[data_col_name], errors='coerce')\n",
        "\n",
        "        # Combine date components into a single 'fecha' column\n",
        "        df = df.dropna(subset=['anio', 'mes', 'dia'])\n",
        "        df['fecha'] = pd.to_datetime(dict(year=df['anio'], month=df['mes'], day=df['dia']), errors='coerce')\n",
        "\n",
        "        df.loc[df[nombre_var] < -900, nombre_var] = np.nan\n",
        "\n",
        "        return df.dropna(subset=['fecha']).set_index('fecha')[[nombre_var]]\n",
        "    except Exception as e:\n",
        "        print(f\"⚠️ Error cargando {ruta}: {e}\")\n",
        "        return pd.DataFrame()\n",
        "\n",
        "print(\"Procesando tu cuenca...\")\n",
        "df_p = leer_variable(archivo_precip, 'Precipitación (mm/día)')\n",
        "df_q = leer_variable(archivo_caudal, 'Caudal (mm/día)')\n",
        "df_t = leer_variable(archivo_temp, 'Temp Máx (°C)')\n",
        "df_e = leer_variable(archivo_etp, 'ETP (mm/día)')\n",
        "\n",
        "df = pd.concat([df_p, df_q, df_t, df_e], axis=1).dropna()\n",
        "df['anio'] = df.index.year\n",
        "df['mes'] = df.index.month\n",
        "\n",
        "print(\"¡Datos listos! Generando análisis...\")\n",
        "\n",
        "# =================================================================\n",
        "# 3. GRÁFICO A: Estacionalidad\n",
        "# =================================================================\n",
        "mensual = df.groupby('mes').mean()\n",
        "\n",
        "fig, ax1 = plt.subplots(figsize=(10, 5))\n",
        "ax1.bar(mensual.index, mensual['Precipitación (mm/día)'], color='#3498db', alpha=0.7, label='Precipitación')\n",
        "ax1.set_xlabel('Mes')\n",
        "ax1.set_ylabel('Precipitación y Caudal (mm/día)')\n",
        "ax1.plot(mensual.index, mensual['Caudal (mm/día)'], color='#2ecc71', marker='o', linewidth=2, label='Caudal')\n",
        "ax1.set_xticks(range(1, 13))\n",
        "ax1.set_xticklabels(['E', 'F', 'M', 'A', 'M', 'J', 'J', 'A', 'S', 'O', 'N', 'D'])\n",
        "\n",
        "ax2 = ax1.twinx()\n",
        "ax2.plot(mensual.index, mensual['Temp Máx (°C)'], color='#e74c3c', marker='s', linewidth=2, label='Temp. Máxima')\n",
        "ax2.set_ylabel('Temperatura Máxima (°C)')\n",
        "\n",
        "fig.legend(loc='upper right', bbox_to_anchor=(0.9, 0.9))\n",
        "plt.title('Estacionalidad: Régimen Hidroclimatológico (Itata en Trilaleo)')\n",
        "plt.grid(True, alpha=0.3)\n",
        "plt.show()\n",
        "\n",
        "# =================================================================\n",
        "# 4. GRÁFICO B: Variabilidad Interanual\n",
        "# =================================================================\n",
        "anual = df.groupby('anio')[['Precipitación (mm/día)', 'Caudal (mm/día)']].sum()\n",
        "promedio_historico = anual['Precipitación (mm/día)'].mean()\n",
        "\n",
        "plt.figure(figsize=(12, 5))\n",
        "bars = plt.bar(anual.index, anual['Precipitación (mm/día)'], color='lightgray')\n",
        "\n",
        "for i, bar in enumerate(bars):\n",
        "    if anual['Precipitación (mm/día)'].iloc[i] > promedio_historico * 1.1:\n",
        "        bar.set_color('#2980b9')\n",
        "    elif anual['Precipitación (mm/día)'].iloc[i] < promedio_historico * 0.9:\n",
        "        bar.set_color('#c0392b')\n",
        "\n",
        "plt.axhline(promedio_historico, color='k', linestyle='--', label=f'Promedio Histórico ({promedio_historico:.0f} mm)')\n",
        "plt.title('Variabilidad Interanual: Años Secos (Rojo) y Húmedos (Azul)')\n",
        "plt.xlabel('Año')\n",
        "plt.ylabel('Precipitación Total Anual (mm)')\n",
        "plt.legend()\n",
        "plt.grid(axis='y', alpha=0.5)\n",
        "plt.show()\n",
        "\n",
        "# =================================================================\n",
        "# 5. GRÁFICO C: Relación Precipitación - Caudal\n",
        "# =================================================================\n",
        "plt.figure(figsize=(7, 6))\n",
        "sns.regplot(x=anual['Precipitación (mm/día)'], y=anual['Caudal (mm/día)'],\n",
        "            scatter_kws={'alpha':0.6, 'color':'#8e44ad'}, line_kws={'color':'k', 'linestyle':'--'})\n",
        "plt.title('Relación Lluvia vs. Escorrentía Anual')\n",
        "plt.xlabel('Precipitación Anual (mm)')\n",
        "plt.ylabel('Caudal Anual acumulado (mm)')\n",
        "plt.grid(True, alpha=0.3)\n",
        "plt.show()"
      ],
