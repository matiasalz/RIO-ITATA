        "# =================================================================\n",
        "# CÁLCULOS EXACTOS PARA EL PUNTO 4 (BALANCE HÍDRICO Y ESCORRENTÍA)\n",
        "# =================================================================\n",
        "\n",
        "# 1. Agrupar los datos por año y sumar para tener totales anuales\n",
        "totales_anuales = df.resample('Y').sum()\n",
        "\n",
        "# 2. Calcular los promedios históricos anuales\n",
        "p_media = totales_anuales['Precipitación (mm/día)'].mean()\n",
        "q_media = totales_anuales['Caudal (mm/día)'].mean()\n",
        "etp_media = totales_anuales['ETP (mm/día)'].mean()\n",
        "\n",
        "# 3. Cálculos de balance\n",
        "coef_escorrentia = q_media / p_media\n",
        "etr_estimada = p_media - q_media  # Asumiendo que el almacenamiento a largo plazo es cero\n",
        "\n",
        "# 4. Mostrar resultados para el informe\n",
        "print(f\"--- RESULTADOS PUNTO 4: BALANCE HÍDRICO MEDIO ANUAL ---\")\n",
        "print(f\"Precipitación Media Anual (P): {p_media:.1f} mm\")\n",
        "print(f\"Caudal Medio Anual (Q): {q_media:.1f} mm\")\n",
        "print(f\"Evapotranspiración Potencial (ETP): {etp_media:.1f} mm\")\n",
        "print(f\"Evapotranspiración Real estimada (ETR): {etr_estimada:.1f} mm\")\n",
        "print(f\"-------------------------------------------------------\")\n",
        "print(f\"Coeficiente de Escorrentía (C): {coef_escorrentia:.3f} ({(coef_escorrentia*100):.1f}%)\")"
      ],
